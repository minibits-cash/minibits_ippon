# Database
DATABASE_URL="postgresql://user:password@localhost:5432/minibits_ippon"

# Server
PORT=3001
LOG_LEVEL=debug

# Mints — comma-separated list of supported Cashu mint URLs.
# The first entry is the default mint used when a wallet is created without specifying a mint.
MINT_URLS=https://mint.minibits.cash/Bitcoin

# Only single wallet unit is supported: choose "sat" or "msat"
UNIT=sat

# Global limits (in wallet unit)
MAX_BALANCE=100000
MAX_SEND=50000
MAX_PAY=50000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_CREATE_WALLET_MAX=3
RATE_LIMIT_WINDOW='1 minute'

# Info endpoint
SERVICE_STATUS=operational
SERVICE_HELP=https://github.com/minibits-cash/minibits_ippon
SERVICE_TERMS=https://github.com/minibits-cash/minibits_ippon